generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id // Supabase Auth user ID (set manually)
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trades    Trade[]
}

model Trade {
  id          String   @id @default(cuid())
  userId      String

  // Options-specific fields
  symbol      String             // NIFTY, BANKNIFTY, FINNIFTY
  optionType  String             // CE or PE
  strikePrice Int                // Strike price e.g. 22500
  expiryDate  DateTime           // Expiry date of the option
  tradeType   String   @default("BUY") // BUY or SELL (option buying vs writing)
  lots        Int                // Number of lots

  // Price fields (premium)
  entryPrice  Float              // Entry premium
  exitPrice   Float?             // Exit premium (null if open)

  // Risk management
  stopLoss    Float?             // Stop loss premium
  target      Float?             // Target premium

  // Calculated fields
  quantity    Int                // lotSize * lots (auto-calculated)
  pnl         Float?             // Gross P&L
  pnlPercent  Float?             // P&L % based on investment
  brokerage   Float?             // Estimated brokerage + charges
  netPnl      Float?             // Net P&L after charges
  rrRatio     Float?             // Risk:Reward ratio

  // Meta
  strategy    String?
  outcome     String   @default("PENDING") // WIN, LOSS, BE, PENDING
  notes       String?
  date        DateTime           // Trade date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  psychology  Psychology?

  @@index([userId])
  @@index([date])
  @@index([symbol])
  @@index([strategy])
  @@index([optionType])
}

model Psychology {
  id             String   @id @default(cuid())
  tradeId        String   @unique
  confidence     Int      @default(5)
  satisfaction   Int      @default(5)
  emotionalState String   @default("Calm")
  mistakes       String?
  lessonsLearned String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  trade          Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model BacktestResult {
  id              String   @id @default(cuid())
  userId          String
  name            String
  symbol          String
  startDate       DateTime
  endDate         DateTime
  strategy        String
  entryCondition  String
  exitCondition   String
  stopLoss        Float?
  takeProfit      Float?
  initialCapital  Float    @default(100000)
  finalCapital    Float?
  totalTrades     Int      @default(0)
  winRate         Float?
  maxDrawdown     Float?
  profitFactor    Float?
  equityCurve     String?
  tradeList       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}
